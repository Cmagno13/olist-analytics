# ============================================================
# Olist Analytics — Variáveis de ambiente (exemplo)
# Copie este arquivo para .env e preencha com seus valores reais
# ============================================================

# Caminho do banco DuckDB local
DUCKDB_PATH=./data/warehouse/olist.duckdb

# Caminho dos CSVs brutos do Olist
RAW_DATA_PATH=./data/raw

# Kaggle API (apenas se quiser baixar via script Python)
# Normalmente já é lido de ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=
